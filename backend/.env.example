GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
CHROMA_DIR=./data/chroma
RATE_LIMIT_PER_HOUR=30
ALLOWED_ORIGINS=*

# Optional: monitored by Kavacha (https://github.com/omshrirao-dev/kavacha).
# Create a "Hanuman Ji" project in your Kavacha dashboard and generate an
# API key there -- leave blank to run with monitoring disabled (no-op).
KAVACHA_API_KEY=
KAVACHA_PROJECT_ID=
KAVACHA_API_URL=https://kavacha-rho.vercel.app
